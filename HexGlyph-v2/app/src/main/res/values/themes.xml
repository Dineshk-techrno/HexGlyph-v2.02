<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Compose requires an AppCompat DayNight base to avoid a white flash on
        launch. All visual theming is handled at runtime by HexGlyphTheme.
    -->
    <style name="Theme.HexGlyph" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
